DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME

GOOGLE_CLOUD_PROJECT=your_project_id
GOOGLE_CLOUD_LOCATION=asia-southeast1
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

VERTEX_GEMINI_MODEL=gemini-2.5-flash
VERTEX_REASONING_MODEL=gemini-2.5-pro
VERTEX_EMBEDDING_MODEL=text-embedding-005
VERTEX_VECTOR_INDEX_ENDPOINT_ID=your_index_endpoint_id

DOCUMENT_AI_PROCESSOR_ID=your_processor_id

ENABLE_BIGQUERY_MCP=true
ENABLE_SPANNER_GRAPH_MCP=true
ENABLE_DOCUMENT_AI_MCP=true
ENABLE_CHIRP_STT_MCP=true

ENABLE_FIRESTORE_MCP=false
ENABLE_GMAIL_MCP=false
ENABLE_DRIVE_MCP=false
ENABLE_CALENDAR_MCP=false

ENABLE_CLOUD_TRANSLATION=true
CLOUD_TRANSLATION_TARGET_LANGUAGE=en

# Vertex AI Search & BigQuery (backend/app/ services)
APP_GCP_PROJECT_ID=your-gcp-project-id
APP_GCP_LOCATION=global
APP_VERTEX_SEARCH_DATA_STORE_ID=your-data-store-id
APP_VERTEX_SEARCH_SERVING_CONFIG_ID=default_serving_config
APP_VERTEX_EMBEDDINGS_MODEL=text-embedding-004
APP_VERTEX_EMBEDDINGS_LOCATION=us-central1
APP_BIGQUERY_PROJECT_ID=your-gcp-project-id
APP_BIGQUERY_LOCATION=US
APP_BIGQUERY_DATASET_ID=vector_dw
APP_BIGQUERY_VECTOR_TABLE=documents
APP_BIGQUERY_VECTOR_INDEX=documents_embedding_idx

NEXT_PUBLIC_API_URL=http://localhost:8000
